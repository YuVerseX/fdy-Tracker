# 应用配置
APP_NAME=江苏专职辅导员招聘追踪系统
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite:///./data/fdy_tracker.db

# 爬虫配置
SCRAPER_INTERVAL=7200
REQUEST_TIMEOUT=30
REQUEST_DELAY_MIN=1
REQUEST_DELAY_MAX=3

# 日志配置
LOG_LEVEL=INFO

# AI 分析配置
AI_ANALYSIS_ENABLED=true
AI_ANALYSIS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_ANALYSIS_MODEL=gpt-5.4
AI_PROMPT_VERSION=v1

# 管理台鉴权
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Docker / VPS 部署可选配置
WEB_PORT=80
GHCR_NAMESPACE=yuversex
IMAGE_TAG=latest
