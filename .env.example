# 应用配置
APP_NAME=江苏专职辅导员招聘追踪系统
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite:///./data/fdy_tracker.db

# 爬虫配置
SCRAPER_INTERVAL=7200
REQUEST_TIMEOUT=30
REQUEST_DELAY_MIN=1
REQUEST_DELAY_MAX=3

# 日志配置
LOG_LEVEL=INFO

# AI 分析配置
AI_ANALYSIS_ENABLED=true
AI_ANALYSIS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_ANALYSIS_MODEL=gpt-5.4
AI_PROMPT_VERSION=v1

# 管理台鉴权
ADMIN_USERNAME=
ADMIN_PASSWORD=
# 至少 32 个随机字符
ADMIN_SESSION_SECRET=
ADMIN_SESSION_MAX_AGE_SECONDS=28800
# 生产 / 部署默认必须为 true；仅限本地纯 HTTP 调试管理台时临时改为 false
ADMIN_SESSION_SECURE=true
# 部署默认关闭 API 文档；本地调试 Swagger 时显式改为 true
API_DOCS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Docker / VPS 部署可选配置
WEB_PORT=80
GHCR_NAMESPACE=yuversex
IMAGE_TAG=latest
